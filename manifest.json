{
  "manifest_version": 3,
  "name": "IOC Inspector",
  "version": "1.0.0",
  "description": "Multi-source URL & IP threat intelligence lookup. VirusTotal, AbuseIPDB, URLScan, OTX, ThreatFox, URLHaus + more.",
  "author": "RYMANTECH",
  "homepage_url": "https://github.com/ree-l/ioc-inspector",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.virustotal.com/*",
    "https://api.abuseipdb.com/*",
    "https://urlscan.io/*",
    "https://otx.alienvault.com/*",
    "https://threatfox-api.abuse.ch/*",
    "https://urlhaus-api.abuse.ch/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "IOC Inspector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
